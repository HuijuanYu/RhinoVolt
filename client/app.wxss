/* app.wxss */
/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  color: #333333;
  background-color: #f5f5f5;
}

/* 容器样式 */
.container {
  padding: 16px;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  padding: 16px;
  margin-bottom: 16px;
}

/* 按钮样式 */
.btn {
  display: inline-block;
  padding: 10px 20px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
  cursor: pointer;
}

.btn-primary {
  background-color: #1890ff;
  color: #ffffff;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #333333;
  border: 1px solid #d9d9d9;
}

/* 表单样式 */
.form-item {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 10px;
  border: 1px solid #d9d9d9;
  border-radius: 4px;
  font-size: 14px;
}

/* 列表样式 */
.list {
  background-color: #ffffff;
}

.list-item {
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-item:last-child {
  border-bottom: none;
}

/* 标题样式 */
h1 {
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 16px;
}

h2 {
  font-size: 18px;
  font-weight: 500;
  margin-bottom: 12px;
}

h3 {
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 8px;
}

/* 文本样式 */
.text-muted {
  color: #999999;
}

.text-primary {
  color: #1890ff;
}

.text-danger {
  color: #ff4d4f;
}

.text-success {
  color: #52c41a;
}

/* 间距样式 */
.mt-1 {
  margin-top: 8px;
}

.mt-2 {
  margin-top: 16px;
}

.mb-1 {
  margin-bottom: 8px;
}

.mb-2 {
  margin-bottom: 16px;
}

/* 加载样式 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px 0;
}

/* 空状态样式 */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 60px 0;
  color: #999999;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}