.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 信息卡片 */
.info-card {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 文档标题 */
.document-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

/* 文档分类 */
.document-category {
  font-size: 22rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
  margin-bottom: 24rpx;
}

/* 文档信息 */
.document-info {
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  margin-bottom: 16rpx;
  align-items: flex-start;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  line-height: 1.4;
}

/* 审批状态 */
.approval-status {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.status-badge {
  font-size: 24rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.status-badge.pending {
  color: #faad14;
  background-color: #fff7e6;
}

.status-badge.approved {
  color: #52c41a;
  background-color: #f6ffed;
}

.status-badge.rejected {
  color: #ff4d4f;
  background-color: #fff2f0;
}

/* 卡片通用样式 */
.content-card,
.approval-card {
  background-color: white;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 卡片头部 */
.card-header {
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

/* 文档内容 */
.document-content {
  padding: 40rpx 24rpx;
  min-height: 300rpx;
}

.content-placeholder {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  line-height: 1.6;
}

.placeholder-text {
  display: block;
  margin-bottom: 16rpx;
}

.hint-text {
  display: block;
  font-size: 22rpx;
}

/* 审批记录 */
.approval-records {
  padding: 24rpx;
}

.approval-item {
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.approval-item:last-child {
  border-bottom: none;
}

.approval-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.approver {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

.approval-time {
  font-size: 22rpx;
  color: #999;
}

.approval-content {
  margin-top: 8rpx;
}

.approval-result {
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
  display: inline-block;
}

.approval-result.approved {
  color: #52c41a;
}

.approval-result.rejected {
  color: #ff4d4f;
}

.approval-comment {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.btn {
  width: 100%;
  padding: 24rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  border: none;
  outline: none;
}

.btn-primary {
  background-color: #1890ff;
  color: white;
}

.btn-secondary {
  background-color: white;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.btn:active {
  opacity: 0.8;
}

/* 响应式调整 */
@media (max-width: 375rpx) {
  .info-label {
    width: 100rpx;
  }
  
  .document-title {
    font-size: 28rpx;
  }
}