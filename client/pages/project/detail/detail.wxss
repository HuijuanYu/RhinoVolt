.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.info-section {
  background-color: white;
  border-radius: 8rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.info-section h2 {
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 0 20rpx 0;
  color: #333;
}

/* 基本信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 进度信息卡片 */
.progress-card {
  padding: 20rpx 0;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-title {
  font-size: 28rpx;
  color: #333;
}

.progress-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background-color: #1890ff;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.schedule-info {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.schedule-item {
  display: flex;
  flex-direction: column;
}

.schedule-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.schedule-value {
  font-size: 24rpx;
  color: #333;
}

/* 参建单位列表 */
.company-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.company-item {
  padding: 20rpx;
  border-left: 4rpx solid #1890ff;
  background-color: #f9f9f9;
  border-radius: 0 8rpx 8rpx 0;
}

.company-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.company-type {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
}

.company-contact {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}

.company-phone {
  font-size: 22rpx;
  color: #999;
  display: block;
}

/* 里程碑列表 */
.milestone-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.milestone-item {
  display: flex;
  gap: 20rpx;
  position: relative;
}

.milestone-item::before {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 50rpx;
  bottom: -20rpx;
  width: 2rpx;
  background-color: #f0f0f0;
}

.milestone-item:last-child::before {
  display: none;
}

.milestone-date {
  width: 100rpx;
  font-size: 22rpx;
  color: #1890ff;
  font-weight: 500;
  padding-top: 4rpx;
}

.milestone-content {
  flex: 1;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.milestone-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.milestone-description {
  font-size: 22rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.milestone-status {
  font-size: 22rpx;
  font-weight: 500;
  display: block;
}

/* 巡检记录列表 */
.inspection-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.inspection-item {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.inspection-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.inspection-date {
  font-size: 22rpx;
  color: #999;
}

.inspection-result {
  font-size: 24rpx;
  font-weight: 500;
}

.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  outline: none;
}

.btn-primary {
  background-color: #1890ff;
  color: white;
}

.btn-secondary {
  background-color: white;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.btn:active {
  opacity: 0.8;
}