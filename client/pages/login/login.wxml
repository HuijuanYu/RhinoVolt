<view class="container">
  <view class="login-form">
    <view class="logo">
      <text class="logo-text">电力新能源</text>
    </view>
    
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input 
        class="form-input" 
        placeholder="请输入手机号" 
        bindinput="bindPhoneInput"
        value="{{phone}}"
        type="number"
        maxlength="11"
      />
    </view>
    
    <view class="form-item">
      <text class="form-label">密码</text>
      <input 
        class="form-input" 
        placeholder="请输入密码" 
        password="{{true}}" 
        bindinput="bindPasswordInput"
        value="{{password}}"
      />
    </view>
    
    <button 
      class="btn btn-primary login-btn" 
      bindtap="handleLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '登录'}}
    </button>
    
    <view class="form-footer">
      <text class="footer-link">忘记密码？</text>
      <text class="footer-link" bindtap="goToRegister">立即注册</text>
    </view>
  </view>
</view>