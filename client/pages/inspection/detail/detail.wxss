.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.info-section,
.inspection-items,
.evaluation-section {
  background-color: white;
  border-radius: 8rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.info-section h2,
.inspection-items h2,
.evaluation-section h2 {
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 0 20rpx 0;
  color: #333;
}

/* 任务信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 巡检项列表 */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item-card {
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  padding: 24rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.item-standard {
  font-size: 22rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.item-content {
  margin-bottom: 20rpx;
}

.item-description {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

/* 检查结果 */
.item-check {
  margin-bottom: 20rpx;
}

.check-label {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.check-options {
  display: flex;
  gap: 40rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.radio-text {
  font-size: 24rpx;
  color: #333;
}

/* 问题描述 */
.item-remark {
  margin-bottom: 20rpx;
}

.remark-label {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.item-remark textarea {
  width: 100%;
  height: 150rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: #333;
  resize: none;
}

/* 问题照片 */
.item-photos {
  margin-bottom: 20rpx;
}

.photos-label {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.photo-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.photo-item {
  width: 150rpx;
  height: 150rpx;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.photo-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-delete {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}

.photo-upload {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 64rpx;
}

/* 总体评价 */
.evaluation-content textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: #333;
  resize: none;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  outline: none;
}

.btn-primary {
  background-color: #1890ff;
  color: white;
}

.btn-secondary {
  background-color: white;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.btn:active {
  opacity: 0.8;
}

/* 响应式调整 */
@media (max-width: 375rpx) {
  .info-grid {
    grid-template-columns: 1fr;
  }
  
  .check-options {
    flex-direction: column;
    gap: 12rpx;
  }
  
  .action-buttons {
    flex-direction: column;
  }
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: white;
  border-radius: 12rpx;
  width: 80%;
  max-width: 500rpx;
  padding: 30rpx;
}

.modal-header {
  margin-bottom: 20rpx;
  text-align: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-body {
  margin-bottom: 30rpx;
  text-align: center;
}

.modal-body text {
  font-size: 28rpx;
  color: #333;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

/* 确认方式选项 */
.confirm-methods {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 30rpx;
}

.method-item {
  padding: 24rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
}

.method-item:active {
  background-color: #e6f7ff;
  border-color: #1890ff;
  color: #1890ff;
}