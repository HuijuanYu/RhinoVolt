.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  text-align: center;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #666;
}

.method-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.method-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: flex-start;
}

.method-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.method-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.method-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.method-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.method-apply {
  background-color: #f0f5ff;
  padding: 16rpx;
  border-radius: 8rpx;
}

.apply-label {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: bold;
}

.apply-text {
  font-size: 24rpx;
  color: #666;
}