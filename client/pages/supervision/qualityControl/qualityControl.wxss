.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  text-align: center;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #666;
}

.section-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.control-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.control-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.control-item:active {
  background-color: #e6f7ff;
}

.control-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.control-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.control-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.control-desc {
  font-size: 24rpx;
  color: #666;
}

.control-arrow {
  font-size: 32rpx;
  color: #999;
}

.record-list, .issue-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item, .issue-item {
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.record-header, .issue-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-title, .issue-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.record-status, .issue-status, .issue-priority {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.record-status.qualified, .issue-status.resolved {
  background-color: #f6ffed;
  color: #52c41a;
}

.record-status.pending, .issue-status.pending {
  background-color: #fff7e6;
  color: #fa8c16;
}

.issue-status.rectifying {
  background-color: #e6f7ff;
  color: #1890ff;
}

.issue-priority.high {
  background-color: #fff1f0;
  color: #f5222d;
}

.issue-priority.medium {
  background-color: #fff7e6;
  color: #fa8c16;
}

.record-info, .issue-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-time, .issue-deadline {
  font-size: 24rpx;
  color: #999;
}

.record-checker {
  font-size: 24rpx;
  color: #666;
}

.issue-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.btn-add {
  margin-top: 20rpx;
  width: 100%;
  height: 80rpx;
  background-color: #1890ff;
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.btn-add:active {
  background-color: #40a9ff;
}