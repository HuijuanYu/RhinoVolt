.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  text-align: center;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #666;
}

.section-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.schedule-overview {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.overview-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.overview-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.overview-value.highlight {
  color: #1890ff;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-item {
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.plan-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.plan-status {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.plan-status.normal {
  background-color: #f6ffed;
  color: #52c41a;
}

.plan-status.delay {
  background-color: #fff1f0;
  color: #f5222d;
}

.plan-status.pending {
  background-color: #f5f5f5;
  color: #999;
}

.plan-progress {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background-color: #e8e8e8;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #52c41a);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: bold;
  width: 60rpx;
  text-align: right;
}

.plan-time {
  display: flex;
  justify-content: space-between;
}

.time-item {
  font-size: 24rpx;
  color: #999;
}

.warning-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.warning-level {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.warning-level.high {
  background-color: #fff1f0;
  color: #f5222d;
}

.warning-level.medium {
  background-color: #fff7e6;
  color: #fa8c16;
}

.warning-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.warning-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.warning-desc {
  font-size: 24rpx;
  color: #666;
}