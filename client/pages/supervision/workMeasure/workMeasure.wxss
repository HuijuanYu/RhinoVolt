.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  text-align: center;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #666;
}

.measure-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.measure-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.measure-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.measure-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.measure-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.measure-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.measure-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
}

.item-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #52c41a;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-text {
  font-size: 28rpx;
  color: #333;
}