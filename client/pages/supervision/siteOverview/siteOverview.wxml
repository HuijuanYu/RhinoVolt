<view class="container">
  <view class="page-header">
    <text class="page-title">🏭 工地概况</text>
    <text class="page-subtitle">工程基本信息与参建单位</text>
  </view>
  
  <!-- 工程基本信息 -->
  <view class="section-card">
    <view class="section-title">
      <text class="title-icon">📋</text>
      <text class="title-text">工程基本信息</text>
    </view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">工程名称</text>
        <text class="info-value">XX新能源发电项目</text>
      </view>
      <view class="info-item">
        <text class="info-label">工程地点</text>
        <text class="info-value">XX省XX市XX区</text>
      </view>
      <view class="info-item">
        <text class="info-label">工程规模</text>
        <text class="info-value">装机容量 100MW</text>
      </view>
      <view class="info-item">
        <text class="info-label">工程类型</text>
        <text class="info-value">光伏发电工程</text>
      </view>
      <view class="info-item">
        <text class="info-label">计划工期</text>
        <text class="info-value">2024年1月 - 2025年6月</text>
      </view>
      <view class="info-item">
        <text class="info-label">工程总投资</text>
        <text class="info-value">约 5.2 亿元</text>
      </view>
    </view>
  </view>
  
  <!-- 参建单位 -->
  <view class="section-card">
    <view class="section-title">
      <text class="title-icon">🏢</text>
      <text class="title-text">参建单位</text>
    </view>
    <view class="unit-list">
      <view class="unit-item">
        <view class="unit-header">
          <text class="unit-type">建设单位</text>
          <text class="unit-name">XX新能源开发有限公司</text>
        </view>
        <view class="unit-contact">
          <text class="contact-item">联系人：张经理</text>
          <text class="contact-item">电话：138-xxxx-xxxx</text>
        </view>
      </view>
      <view class="unit-item">
        <view class="unit-header">
          <text class="unit-type">设计单位</text>
          <text class="unit-name">XX电力设计院</text>
        </view>
        <view class="unit-contact">
          <text class="contact-item">联系人：李工</text>
          <text class="contact-item">电话：139-xxxx-xxxx</text>
        </view>
      </view>
      <view class="unit-item">
        <view class="unit-header">
          <text class="unit-type">施工单位</text>
          <text class="unit-name">XX电力建设集团有限公司</text>
        </view>
        <view class="unit-contact">
          <text class="contact-item">联系人：王经理</text>
          <text class="contact-item">电话：137-xxxx-xxxx</text>
        </view>
      </view>
      <view class="unit-item">
        <view class="unit-header">
          <text class="unit-type">监理单位</text>
          <text class="unit-name">XX工程监理有限公司</text>
        </view>
        <view class="unit-contact">
          <text class="contact-item">联系人：刘总监</text>
          <text class="contact-item">电话：136-xxxx-xxxx</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 工程进度 -->
  <view class="section-card">
    <view class="section-title">
      <text class="title-icon">📊</text>
      <text class="title-text">工程进度</text>
    </view>
    <view class="progress-section">
      <view class="progress-item">
        <view class="progress-header">
          <text class="progress-label">总体进度</text>
          <text class="progress-value">45%</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: 45%"></view>
        </view>
      </view>
      <view class="progress-item">
        <view class="progress-header">
          <text class="progress-label">土建工程</text>
          <text class="progress-value">60%</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: 60%"></view>
        </view>
      </view>
      <view class="progress-item">
        <view class="progress-header">
          <text class="progress-label">设备安装</text>
          <text class="progress-value">30%</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: 30%"></view>
        </view>
      </view>
      <view class="progress-item">
        <view class="progress-header">
          <text class="progress-label">电气安装</text>
          <text class="progress-value">20%</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: 20%"></view>
        </view>
      </view>
    </view>
  </view>
</view>