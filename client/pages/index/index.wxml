<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <view class="avatar">
        <text class="avatar-text">{{userInfo.name.charAt(0)}}</text>
      </view>
      <view class="user-details">
        <text class="user-name">{{userInfo.name}}</text>
        <text class="user-role">{{userInfo.role === 'supervisor' ? '监理工程师' : '管理员'}}</text>
      </view>
    </view>
    <view class="user-actions">
      <text class="action-btn" bindtap="handleLogout">退出登录</text>
    </view>
  </view>
  
  <!-- 待办事项 -->
  <view class="todo-section">
    <view class="section-header">
      <text class="section-title">待办事项</text>
      <text class="section-more">查看全部</text>
    </view>
    <view class="todo-list">
      <view class="todo-item" wx:for="{{todoList}}" wx:key="id">
        <view class="todo-content">
          <text class="todo-title">{{item.title}}</text>
          <text class="todo-time">{{item.time}}</text>
        </view>
        <view class="todo-status" style="color: {{item.status === 'urgent' ? '#ff4d4f' : '#1890ff'}}">
          {{item.status === 'urgent' ? '紧急' : '待处理'}}
        </view>
      </view>
      <view class="empty" wx:if="{{todoList.length === 0}}">
        <text>暂无待办事项</text>
      </view>
    </view>
  </view>
  
  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="navigateToProject">
      <view class="action-icon">
        <text class="icon-text">🏗️</text>
      </view>
      <text class="action-text">工程管理</text>
    </view>
    <view class="action-item" bindtap="navigateToInspection">
      <view class="action-icon">
        <text class="icon-text">🔍</text>
      </view>
      <text class="action-text">日常巡检</text>
    </view>
    <view class="action-item" bindtap="navigateToDocument">
      <view class="action-icon">
        <text class="icon-text">📄</text>
      </view>
      <text class="action-text">文档管理</text>
    </view>
    <view class="action-item" bindtap="navigateToApproval">
      <view class="action-icon">
        <text class="icon-text">✅</text>
      </view>
      <text class="action-text">审批流程</text>
    </view>
  </view>
  
  <!-- 监理工作模块 -->
  <view class="supervision-section">
    <view class="section-header">
      <text class="section-title">监理工作</text>
    </view>
    <view class="supervision-grid">
      <view class="supervision-item" bindtap="navigateToSiteOverview">
        <view class="supervision-icon site">
          <text class="icon-text">🏭</text>
        </view>
        <text class="supervision-text">工地概况</text>
      </view>
      <view class="supervision-item" bindtap="navigateToWorkBasis">
        <view class="supervision-icon basis">
          <text class="icon-text">📋</text>
        </view>
        <text class="supervision-text">监理依据</text>
      </view>
      <view class="supervision-item" bindtap="navigateToProjectFeatures">
        <view class="supervision-icon feature">
          <text class="icon-text">🔧</text>
        </view>
        <text class="supervision-text">工程特点</text>
      </view>
      <view class="supervision-item" bindtap="navigateToWorkFlow">
        <view class="supervision-icon flow">
          <text class="icon-text">🔄</text>
        </view>
        <text class="supervision-text">工作流程</text>
      </view>
      <view class="supervision-item" bindtap="navigateToWorkMethod">
        <view class="supervision-icon method">
          <text class="icon-text">🎯</text>
        </view>
        <text class="supervision-text">工作方法</text>
      </view>
      <view class="supervision-item" bindtap="navigateToWorkMeasure">
        <view class="supervision-icon measure">
          <text class="icon-text">🛡️</text>
        </view>
        <text class="supervision-text">工作措施</text>
      </view>
      <view class="supervision-item" bindtap="navigateToQualityControl">
        <view class="supervision-icon quality">
          <text class="icon-text">✨</text>
        </view>
        <text class="supervision-text">质量控制</text>
      </view>
      <view class="supervision-item" bindtap="navigateToScheduleControl">
        <view class="supervision-icon schedule">
          <text class="icon-text">⏱️</text>
        </view>
        <text class="supervision-text">进度控制</text>
      </view>
    </view>
  </view>
  
  <!-- 最近工程 -->
  <view class="recent-projects">
    <view class="section-header">
      <text class="section-title">最近工程</text>
      <text class="section-more">查看全部</text>
    </view>
    <view class="project-list">
      <view class="project-item" wx:for="{{recentProjects}}" wx:key="id">
        <text class="project-name">{{item.name}}</text>
        <text class="project-progress">{{item.progress}}%</text>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.progress}}%"></view>
        </view>
      </view>
      <view class="empty" wx:if="{{recentProjects.length === 0}}">
        <text>暂无工程信息</text>
      </view>
    </view>
  </view>
</view>